{
  "routes": [
    {
      "from": "code-reviewer",
      "to": "release-manager",
      "type": "finding",
      "when": "code quality trends or recurring issues detected across PRs"
    },
    {
      "from": "api-tester",
      "to": "bug-triage",
      "type": "alert",
      "when": "test failures or new regression detected"
    },
    {
      "from": "api-tester",
      "to": "sre-devops",
      "type": "alert",
      "when": "performance regression or latency spike detected"
    },
    {
      "from": "devops-automator",
      "to": "sre-devops",
      "type": "alert",
      "when": "pipeline failure or infrastructure alert"
    },
    {
      "from": "bug-triage",
      "to": "code-reviewer",
      "type": "request",
      "when": "high-priority bug needs code review"
    },
    {
      "from": "bug-triage",
      "to": "release-manager",
      "type": "alert",
      "when": "release-blocking bug identified"
    },
    {
      "from": "release-manager",
      "to": "sre-devops",
      "type": "request",
      "when": "deployment coordination or rollback needed"
    },
    {
      "from": "sre-devops",
      "to": "bug-triage",
      "type": "alert",
      "when": "production incident requiring triage"
    }
  ]
}
