{
  "routes": [
    {
      "from": "customer-support",
      "to": "product-owner",
      "type": "finding",
      "when": "feature requests or user pain points identified"
    },
    {
      "from": "customer-support",
      "to": "experiment-tracker",
      "type": "finding",
      "when": "user behavior signals relevant to running experiments"
    },
    {
      "from": "experiment-tracker",
      "to": "product-owner",
      "type": "finding",
      "when": "statistically significant experiment results"
    },
    {
      "from": "experiment-tracker",
      "to": "executive-assistant",
      "type": "finding",
      "when": "strategic experiment outcomes requiring leadership attention"
    },
    {
      "from": "sprint-planner",
      "to": "product-owner",
      "type": "alert",
      "when": "capacity or velocity concerns affecting sprint delivery"
    },
    {
      "from": "sprint-planner",
      "to": "executive-assistant",
      "type": "alert",
      "when": "sprint risk flags or delivery timeline at risk"
    },
    {
      "from": "product-owner",
      "to": "sprint-planner",
      "type": "request",
      "when": "priority changes requiring sprint re-planning"
    },
    {
      "from": "product-owner",
      "to": "executive-assistant",
      "type": "finding",
      "when": "roadmap decisions or strategic trade-offs"
    },
    {
      "from": "executive-assistant",
      "to": "product-owner",
      "type": "request",
      "when": "needs cross-domain analysis"
    },
    {
      "from": "executive-assistant",
      "to": "sprint-planner",
      "type": "request",
      "when": "needs cross-domain analysis"
    },
    {
      "from": "executive-assistant",
      "to": "experiment-tracker",
      "type": "request",
      "when": "needs cross-domain analysis"
    },
    {
      "from": "executive-assistant",
      "to": "customer-support",
      "type": "request",
      "when": "needs cross-domain analysis"
    }
  ]
}
