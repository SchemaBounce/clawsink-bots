        "title": {"type": "string", "required": true, "description": "Content title or headline"},
        "body": {"type": "string", "required": true, "description": "Content body text"},
        "status": {"type": "string", "enum": ["draft", "pending_approval", "approved", "published", "archived"], "description": "Content workflow status"},
        "seo_score": {"type": "number", "description": "SEO optimization score (0-100)"}
      }
    },
    {
