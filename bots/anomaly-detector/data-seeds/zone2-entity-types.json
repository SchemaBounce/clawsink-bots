        "actual_value": {"type": "number", "description": "Observed anomalous value"},
        "deviation": {"type": "number", "description": "Standard deviations from baseline"}
      }
    },
    {
      "name": "anomaly_alerts",
      "displayName": "Anomaly Alerts",
      "description": "Urgent anomaly alerts requiring immediate attention",
      "domain": "engineering",
      "fields": {
        "severity": {"type": "string", "required": true, "enum": ["high", "critical"], "description": "Alert severity"},
        "title": {"type": "string", "required": true, "description": "Alert title"},
        "description": {"type": "string", "required": true, "description": "Alert details"},
