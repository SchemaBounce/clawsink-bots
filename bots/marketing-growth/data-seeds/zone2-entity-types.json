        "trend_direction": {"type": "string", "enum": ["improving", "stable", "declining"], "description": "Trend direction"},
        "description": {"type": "string", "required": true, "description": "Finding description"},
        "recommendation": {"type": "string", "description": "Recommended action"}
      }
    },
    {
      "name": "mktg_alerts",
      "displayName": "Marketing Alerts",
