{
  "entityTypes": [
    {
      "name": "pipeline_route_audit",
      "description": "Per-route health + cost-relevant signal snapshot captured by the analyzer sub-agent. The recommender consumes these to generate pipeline_cost_recommendation records. The analyzer also produces a __workspace_rollup__ row per run summarising aggregate counts. Field set is constrained to what the runtime built-ins actually expose (no per-window event counts, no per-route error rates, no sink configuration details).",
      "fields": {
        "route_id": {"type": "string", "required": true, "description": "Pipeline route id, or __workspace_rollup__ / __no_routes__ / __truncated__ for synthetic rows"},
        "route_name": {"type": "string", "required": false},
        "status": {"type": "string", "required": true, "description": "active | paused | errored | unknown | rollup"},
        "source_type": {"type": "string", "required": false},
        "sink_count": {"type": "integer", "required": false},
        "sink_types": {"type": "array", "items": {"type": "string"}, "required": false},
        "attached_sink_ids": {"type": "array", "items": {"type": "string"}, "required": false},
        "sinks_without_dlq": {"type": "array", "items": {"type": "string"}, "required": false},
        "sinks_without_retry": {"type": "array", "items": {"type": "string"}, "required": false},
        "sinks_with_high_error_rate": {"type": "array", "items": {"type": "string"}, "required": false},
        "events_processed_lifetime": {"type": "integer", "required": false},
        "last_event_at": {"type": "timestamp", "required": false},
        "days_since_last_event": {"type": "integer", "required": false},
        "is_idle": {"type": "boolean", "required": false},
        "events_24h": {"type": "integer", "required": false, "description": "From adl_get_route_metrics 24h window"},
        "events_7d": {"type": "integer", "required": false, "description": "From adl_get_route_metrics 7d window"},
        "events_30d": {"type": "integer", "required": false, "description": "From adl_get_route_metrics 30d window"},
        "successful_30d": {"type": "integer", "required": false},
        "failed_30d": {"type": "integer", "required": false},
        "retried_30d": {"type": "integer", "required": false},
        "failure_rate_30d": {"type": "number", "required": false},
        "avg_processing_ms_30d": {"type": "number", "required": false},
        "lifetime_volume_bucket": {"type": "string", "required": false, "enum": ["none", "low", "med", "high", "unknown"]},
        "active_volume_bucket": {"type": "string", "required": false, "enum": ["none", "low", "med", "high", "unknown"], "description": "Bucket relative to events_30d across active routes"},
        "historically_active_now_idle": {"type": "boolean", "required": false, "description": "events_processed_lifetime > 0 AND events_30d == 0"},
        "created_at": {"type": "timestamp", "required": false},
        "updated_at": {"type": "timestamp", "required": false},
        "total_routes": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "idle_routes": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "errored_routes": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "median_days_since_last_event": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "total_lifetime_events": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "total_events_30d": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "workspace_failure_rate_30d": {"type": "number", "required": false, "description": "Workspace rollup only"},
        "total_sink_count": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "sinks_without_dlq_count": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "sinks_without_retry_count": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "configured_sources": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "orphan_sources": {"type": "integer", "required": false, "description": "Workspace rollup only"},
        "audited_at": {"type": "timestamp", "required": true}
      }
    },
    {
      "name": "pipeline_cost_recommendation",
      "description": "An actionable cost recommendation produced by the recommender sub-agent. Reviewed by ops or routed to release-manager for implementation. Recommendations are dry-run only; this bot does not modify infrastructure.",
      "fields": {
        "route_id": {"type": "string", "required": true},
        "route_name": {"type": "string", "required": false},
        "finding_type": {"type": "string", "required": true, "enum": ["idle_route", "high_run_rate", "elevated_failure_rate", "no_dlq_on_high_volume", "no_retry_policy", "fanout_oversized", "errored_route", "orphan_source", "setup_gap", "cost_data_missing"]},
        "severity": {"type": "string", "required": true, "enum": ["info", "warning", "critical"]},
        "current_metric": {"type": "object", "required": false, "description": "JSON blob with the actual platform-exposed metric values that triggered the rule (e.g., {days_since_last_event: 47, events_processed_lifetime: 0, sink_count: 2})"},
        "projected_savings": {"type": "string", "required": false, "description": "Plain-text qualitative estimate of the cost or operational benefit. Cites the sinks affected; does NOT claim dollar figures unless sink_cost_table has full coverage for the sinks involved."},
        "suggested_action": {"type": "string", "required": true, "description": "Concrete one-paragraph action a human or release-manager can execute. No hype verbs."},
        "suggested_owner": {"type": "string", "required": false, "enum": ["release-manager", "executive-assistant", "human-ops", "sre-devops"], "description": "Bot or human role best suited to act on this recommendation"},
        "audit_id": {"type": "string", "required": false, "description": "ID of the pipeline_route_audit record this recommendation was derived from"},
        "first_detected_at": {"type": "timestamp", "required": true},
        "last_seen_at": {"type": "timestamp", "required": false, "description": "Updated each run the same finding persists"},
        "consecutive_runs_seen": {"type": "integer", "required": false, "description": "How many runs in a row this finding has been emitted"},
        "notify_again": {"type": "boolean", "required": false, "description": "Set true after 3+ consecutive runs to re-ping executive-assistant"},
        "status": {"type": "string", "required": true, "enum": ["open", "dismissed", "resolved"], "description": "Operator state. Bot only writes 'open'; humans/release-manager flip to dismissed/resolved."}
      }
    }
  ]
}
