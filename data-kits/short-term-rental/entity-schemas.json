[
  {
    "name": "str_properties",
    "displayName": "Properties",
    "description": "Property listings with details, amenities, house rules, capacity, and access information",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Property listing name as shown to guests"
      },
      "address": {
        "type": "string",
        "required": true,
        "description": "Full street address"
      },
      "city": {
        "type": "string",
        "required": true,
        "description": "City or town"
      },
      "state": {
        "type": "string",
        "required": true,
        "description": "State or province"
      },
      "zip": {
        "type": "string",
        "required": true,
        "description": "Postal or ZIP code"
      },
      "country": {
        "type": "string",
        "required": true,
        "description": "Country code (ISO 3166-1 alpha-2)"
      },
      "property_type": {
        "type": "string",
        "required": true,
        "description": "Type of property",
        "enum": ["house", "apartment", "condo", "cabin", "villa", "studio"]
      },
      "bedrooms": {
        "type": "number",
        "required": true,
        "description": "Number of bedrooms"
      },
      "bathrooms": {
        "type": "number",
        "required": true,
        "description": "Number of bathrooms (supports half baths as decimals, e.g. 1.5)"
      },
      "max_guests": {
        "type": "number",
        "required": true,
        "description": "Maximum guest capacity"
      },
      "square_feet": {
        "type": "number",
        "required": false,
        "description": "Interior living space in square feet"
      },
      "amenities": {
        "type": "array",
        "required": false,
        "description": "List of amenities (wifi, pool, hot_tub, washer, dryer, kitchen, parking, gym, fireplace, ac, heating, tv, bbq, pet_friendly, ev_charger)"
      },
      "house_rules": {
        "type": "array",
        "required": false,
        "description": "List of house rules (no_smoking, no_parties, quiet_hours_10pm, no_shoes_inside, etc.)"
      },
      "check_in_time": {
        "type": "string",
        "required": true,
        "description": "Standard check-in time (HH:MM format)"
      },
      "check_out_time": {
        "type": "string",
        "required": true,
        "description": "Standard check-out time (HH:MM format)"
      },
      "cleaning_fee": {
        "type": "number",
        "required": true,
        "description": "Flat cleaning fee charged per stay in local currency"
      },
      "pet_policy": {
        "type": "string",
        "required": false,
        "description": "Pet policy details",
        "enum": ["no_pets", "dogs_only", "cats_only", "small_pets", "all_pets"]
      },
      "wifi_password": {
        "type": "string",
        "required": false,
        "description": "WiFi network password for guest welcome message"
      },
      "lockbox_code": {
        "type": "string",
        "required": false,
        "description": "Self-check-in lockbox or smart lock code"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current property status",
        "enum": ["active", "inactive", "maintenance", "blocked"]
      },
      "description": {
        "type": "string",
        "required": false,
        "description": "Full property description for listings"
      },
      "neighborhood_guide": {
        "type": "string",
        "required": false,
        "description": "Local area guide with restaurant, attraction, and transit recommendations"
      }
    }
  },
  {
    "name": "str_bookings",
    "displayName": "Bookings",
    "description": "Reservations across all channels with financial details and status tracking",
    "fields": {
      "property_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_properties entity"
      },
      "guest_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_guests entity"
      },
      "channel": {
        "type": "string",
        "required": true,
        "description": "Booking source channel",
        "enum": ["airbnb", "vrbo", "lodgify", "direct", "facebook_marketplace"]
      },
      "channel_booking_id": {
        "type": "string",
        "required": false,
        "description": "Booking ID on the source channel for cross-referencing"
      },
      "check_in": {
        "type": "date",
        "required": true,
        "description": "Check-in date (ISO 8601)"
      },
      "check_out": {
        "type": "date",
        "required": true,
        "description": "Check-out date (ISO 8601)"
      },
      "nights": {
        "type": "number",
        "required": true,
        "description": "Total number of nights"
      },
      "nightly_rate": {
        "type": "number",
        "required": true,
        "description": "Average nightly rate charged in local currency"
      },
      "cleaning_fee": {
        "type": "number",
        "required": true,
        "description": "Cleaning fee charged for this booking"
      },
      "service_fee": {
        "type": "number",
        "required": false,
        "description": "Channel service fee (guest-side or host-side depending on platform)"
      },
      "total_amount": {
        "type": "number",
        "required": true,
        "description": "Total amount charged to the guest"
      },
      "payout_amount": {
        "type": "number",
        "required": true,
        "description": "Net amount paid out to the host after all fees"
      },
      "guest_count": {
        "type": "number",
        "required": true,
        "description": "Number of guests for this booking"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current booking status",
        "enum": ["inquiry", "confirmed", "checked_in", "checked_out", "cancelled", "no_show"]
      },
      "special_requests": {
        "type": "string",
        "required": false,
        "description": "Guest special requests or notes"
      },
      "cancellation_reason": {
        "type": "string",
        "required": false,
        "description": "Reason for cancellation if status is cancelled"
      }
    }
  },
  {
    "name": "str_guests",
    "displayName": "Guests",
    "description": "Guest profiles aggregated across all booking channels with lifetime value tracking",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Guest full name"
      },
      "email": {
        "type": "string",
        "required": false,
        "description": "Guest email address"
      },
      "phone": {
        "type": "string",
        "required": false,
        "description": "Guest phone number"
      },
      "channel_profiles": {
        "type": "object",
        "required": false,
        "description": "Map of channel name to profile ID for cross-channel identity stitching (e.g. {\"airbnb\": \"user_abc123\", \"vrbo\": \"traveler_xyz\"})"
      },
      "preferred_language": {
        "type": "string",
        "required": false,
        "description": "Guest preferred language (ISO 639-1 code)"
      },
      "nationality": {
        "type": "string",
        "required": false,
        "description": "Guest nationality or country of origin"
      },
      "total_stays": {
        "type": "number",
        "required": false,
        "description": "Total number of completed stays across all properties"
      },
      "average_rating_given": {
        "type": "number",
        "required": false,
        "description": "Average rating this guest gives (1-5 scale)"
      },
      "vip_status": {
        "type": "boolean",
        "required": false,
        "description": "Whether this guest is flagged as VIP (repeat booker, high-value, influencer)"
      },
      "notes": {
        "type": "string",
        "required": false,
        "description": "Internal notes about guest preferences, issues, or special handling"
      },
      "first_stay_date": {
        "type": "date",
        "required": false,
        "description": "Date of guest's first stay (ISO 8601)"
      },
      "last_stay_date": {
        "type": "date",
        "required": false,
        "description": "Date of guest's most recent stay (ISO 8601)"
      },
      "lifetime_value": {
        "type": "number",
        "required": false,
        "description": "Total revenue generated by this guest across all bookings"
      }
    }
  },
  {
    "name": "str_reviews",
    "displayName": "Reviews",
    "description": "Guest reviews from all platforms with category breakdowns and host responses",
    "fields": {
      "property_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_properties entity"
      },
      "guest_id": {
        "type": "string",
        "required": false,
        "description": "Reference to the str_guests entity"
      },
      "booking_id": {
        "type": "string",
        "required": false,
        "description": "Reference to the str_bookings entity"
      },
      "channel": {
        "type": "string",
        "required": true,
        "description": "Platform where the review was posted",
        "enum": ["airbnb", "vrbo", "lodgify", "google", "direct"]
      },
      "rating": {
        "type": "number",
        "required": true,
        "description": "Overall star rating (1-5)"
      },
      "review_text": {
        "type": "string",
        "required": false,
        "description": "Full text of the guest review"
      },
      "host_response": {
        "type": "string",
        "required": false,
        "description": "Host's public response to the review"
      },
      "review_date": {
        "type": "date",
        "required": true,
        "description": "Date the review was posted (ISO 8601)"
      },
      "response_date": {
        "type": "date",
        "required": false,
        "description": "Date the host responded (ISO 8601)"
      },
      "categories": {
        "type": "object",
        "required": false,
        "description": "Category-level ratings as key-value pairs (cleanliness, communication, check_in, accuracy, location, value) each 1-5"
      },
      "public": {
        "type": "boolean",
        "required": true,
        "description": "Whether this review is publicly visible on the platform"
      }
    }
  },
  {
    "name": "str_channel_listings",
    "displayName": "Channel Listings",
    "description": "Per-channel listing status, sync health, and channel-specific configuration",
    "fields": {
      "property_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_properties entity"
      },
      "channel": {
        "type": "string",
        "required": true,
        "description": "Distribution channel",
        "enum": ["airbnb", "vrbo", "lodgify", "booking_com", "direct", "facebook_marketplace"]
      },
      "channel_listing_id": {
        "type": "string",
        "required": false,
        "description": "Listing ID on the channel platform"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current listing status on this channel",
        "enum": ["active", "paused", "pending", "rejected"]
      },
      "listing_url": {
        "type": "string",
        "required": false,
        "description": "Direct URL to the listing on the channel"
      },
      "last_synced_at": {
        "type": "date",
        "required": false,
        "description": "Last successful calendar/pricing sync timestamp (ISO 8601)"
      },
      "sync_status": {
        "type": "string",
        "required": true,
        "description": "Current synchronization status",
        "enum": ["synced", "pending", "error"]
      },
      "nightly_rate_override": {
        "type": "number",
        "required": false,
        "description": "Channel-specific nightly rate override (null means use base rate)"
      },
      "minimum_stay": {
        "type": "number",
        "required": false,
        "description": "Minimum stay in nights for this channel"
      },
      "maximum_stay": {
        "type": "number",
        "required": false,
        "description": "Maximum stay in nights for this channel"
      },
      "instant_book_enabled": {
        "type": "boolean",
        "required": false,
        "description": "Whether instant booking is enabled on this channel"
      },
      "auto_pricing_enabled": {
        "type": "boolean",
        "required": false,
        "description": "Whether the channel's auto-pricing tool is active"
      }
    }
  },
  {
    "name": "str_pricing_calendar",
    "displayName": "Pricing Calendar",
    "description": "Date-specific pricing, availability, and demand signals for each property",
    "fields": {
      "property_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_properties entity"
      },
      "date": {
        "type": "date",
        "required": true,
        "description": "Calendar date (ISO 8601)"
      },
      "base_rate": {
        "type": "number",
        "required": true,
        "description": "Standard nightly rate before adjustments"
      },
      "adjusted_rate": {
        "type": "number",
        "required": true,
        "description": "Final nightly rate after all adjustments"
      },
      "minimum_stay": {
        "type": "number",
        "required": false,
        "description": "Minimum stay requirement for this date"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Availability status for this date",
        "enum": ["available", "booked", "blocked", "maintenance"]
      },
      "adjustment_reason": {
        "type": "string",
        "required": false,
        "description": "Reason for price adjustment from base rate",
        "enum": ["demand", "event", "seasonal", "manual", "weekend"]
      },
      "occupancy_probability": {
        "type": "number",
        "required": false,
        "description": "Predicted probability of booking this date (0.0-1.0)"
      },
      "competitor_avg_rate": {
        "type": "number",
        "required": false,
        "description": "Average competitor nightly rate for comparable properties on this date"
      }
    }
  },
  {
    "name": "str_turnovers",
    "displayName": "Turnovers",
    "description": "Cleaning and maintenance events between guest stays with inspection tracking",
    "fields": {
      "property_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_properties entity"
      },
      "booking_id": {
        "type": "string",
        "required": false,
        "description": "Reference to the outgoing str_bookings entity (the stay that just ended)"
      },
      "turnover_date": {
        "type": "date",
        "required": true,
        "description": "Date of the turnover (ISO 8601)"
      },
      "cleaner_name": {
        "type": "string",
        "required": true,
        "description": "Name of the assigned cleaner or cleaning team"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current turnover status",
        "enum": ["scheduled", "in_progress", "completed", "issue_reported"]
      },
      "check_out_time": {
        "type": "string",
        "required": false,
        "description": "Actual guest check-out time (HH:MM format)"
      },
      "next_check_in_time": {
        "type": "string",
        "required": false,
        "description": "Next guest check-in time (HH:MM format)"
      },
      "cleaning_fee": {
        "type": "number",
        "required": true,
        "description": "Fee paid to cleaning team for this turnover"
      },
      "special_instructions": {
        "type": "string",
        "required": false,
        "description": "Special cleaning or staging instructions"
      },
      "inspection_notes": {
        "type": "string",
        "required": false,
        "description": "Post-cleaning inspection notes"
      },
      "photos_uploaded": {
        "type": "boolean",
        "required": false,
        "description": "Whether post-cleaning photos were uploaded"
      },
      "issue_description": {
        "type": "string",
        "required": false,
        "description": "Description of any issue found during turnover (damage, missing items, maintenance needed)"
      }
    }
  },
  {
    "name": "str_messages",
    "displayName": "Messages",
    "description": "Guest communications across all channels with response time metrics and sentiment",
    "fields": {
      "property_id": {
        "type": "string",
        "required": false,
        "description": "Reference to the str_properties entity"
      },
      "guest_id": {
        "type": "string",
        "required": true,
        "description": "Reference to the str_guests entity"
      },
      "booking_id": {
        "type": "string",
        "required": false,
        "description": "Reference to the str_bookings entity if message relates to a specific booking"
      },
      "channel": {
        "type": "string",
        "required": true,
        "description": "Communication channel",
        "enum": ["airbnb", "vrbo", "lodgify", "direct_email", "sms", "whatsapp"]
      },
      "direction": {
        "type": "string",
        "required": true,
        "description": "Message direction",
        "enum": ["inbound", "outbound"]
      },
      "message_text": {
        "type": "string",
        "required": true,
        "description": "Full message content"
      },
      "sent_at": {
        "type": "date",
        "required": true,
        "description": "Timestamp when message was sent (ISO 8601)"
      },
      "read_at": {
        "type": "date",
        "required": false,
        "description": "Timestamp when message was read (ISO 8601)"
      },
      "auto_response": {
        "type": "boolean",
        "required": false,
        "description": "Whether this message was sent by an auto-responder or AI agent"
      },
      "response_time_minutes": {
        "type": "number",
        "required": false,
        "description": "Minutes between guest message and host response (only set on outbound replies)"
      },
      "template_used": {
        "type": "string",
        "required": false,
        "description": "Name of the message template used, if any"
      },
      "sentiment": {
        "type": "string",
        "required": false,
        "description": "AI-detected message sentiment",
        "enum": ["positive", "neutral", "negative", "urgent"]
      }
    }
  }
]
