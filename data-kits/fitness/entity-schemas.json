[
  {
    "name": "fit_members",
    "displayName": "Members",
    "description": "Gym and studio members with profile, fitness goals, and engagement tracking",
    "fields": {
      "first_name": {"type": "string", "required": true, "description": "Member first name"},
      "last_name": {"type": "string", "required": true, "description": "Member last name"},
      "email": {"type": "string", "required": true, "description": "Email address"},
      "phone": {"type": "string", "description": "Phone number"},
      "join_date": {"type": "date", "required": true, "description": "Date member joined"},
      "status": {"type": "string", "required": true, "enum": ["active", "paused", "cancelled", "expired"], "description": "Current membership status"},
      "fitness_goals": {"type": "array", "description": "Member's stated fitness goals"},
      "emergency_contact": {"type": "string", "description": "Emergency contact name and phone"},
      "date_of_birth": {"type": "date", "description": "Date of birth for age-appropriate class recommendations"},
      "referral_source": {"type": "string", "enum": ["walk_in", "website", "social_media", "referral", "corporate", "event"], "description": "How the member found the studio"}
    }
  },
  {
    "name": "fit_classes",
    "displayName": "Classes",
    "description": "Scheduled fitness classes with instructor, capacity, and category details",
    "fields": {
      "name": {"type": "string", "required": true, "description": "Class name"},
      "category": {"type": "string", "required": true, "enum": ["strength", "cardio", "yoga", "pilates", "cycling", "hiit", "dance", "martial_arts", "recovery", "specialty"], "description": "Class category"},
      "instructor": {"type": "string", "required": true, "description": "Instructor name"},
      "day_of_week": {"type": "string", "required": true, "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"], "description": "Scheduled day"},
      "start_time": {"type": "string", "required": true, "description": "Class start time (HH:MM format)"},
      "duration_minutes": {"type": "number", "required": true, "description": "Class duration in minutes"},
      "max_capacity": {"type": "number", "required": true, "description": "Maximum number of participants"},
      "difficulty_level": {"type": "string", "required": true, "enum": ["beginner", "intermediate", "advanced", "all_levels"], "description": "Target skill level"},
      "room": {"type": "string", "description": "Studio room or area"},
      "active": {"type": "boolean", "required": true, "description": "Whether this class is currently on the schedule"}
    }
  },
  {
    "name": "fit_attendance",
    "displayName": "Attendance",
    "description": "Per-class check-in records linking members to class sessions",
    "fields": {
      "member_id": {"type": "string", "required": true, "description": "Reference to fit_members"},
      "class_id": {"type": "string", "required": true, "description": "Reference to fit_classes"},
      "date": {"type": "date", "required": true, "description": "Date of the class session"},
      "check_in_time": {"type": "string", "required": true, "description": "Actual check-in time (HH:MM format)"},
      "status": {"type": "string", "required": true, "enum": ["attended", "no_show", "late_cancel", "waitlisted"], "description": "Attendance status"},
      "booked_via": {"type": "string", "enum": ["app", "front_desk", "website", "auto_recurring"], "description": "How the booking was made"},
      "rating": {"type": "number", "description": "Post-class rating (1-5)"},
      "notes": {"type": "string", "description": "Member feedback or staff notes"}
    }
  },
  {
    "name": "fit_memberships",
    "displayName": "Memberships",
    "description": "Membership plans with pricing, duration, and billing status",
    "fields": {
      "member_id": {"type": "string", "required": true, "description": "Reference to fit_members"},
      "plan_name": {"type": "string", "required": true, "description": "Membership plan name"},
      "plan_type": {"type": "string", "required": true, "enum": ["unlimited", "class_pack", "drop_in", "corporate", "student", "family"], "description": "Type of membership plan"},
      "monthly_rate": {"type": "number", "required": true, "description": "Monthly membership fee in USD"},
      "start_date": {"type": "date", "required": true, "description": "Membership start date"},
      "end_date": {"type": "date", "description": "Membership end date (null for ongoing)"},
      "status": {"type": "string", "required": true, "enum": ["active", "past_due", "paused", "cancelled", "expired"], "description": "Billing status"},
      "classes_remaining": {"type": "number", "description": "Remaining classes for class-pack memberships"},
      "auto_renew": {"type": "boolean", "required": true, "description": "Whether membership auto-renews"},
      "payment_method": {"type": "string", "enum": ["credit_card", "ach", "cash", "corporate_billing"], "description": "Payment method on file"}
    }
  }
]
