[
  {
    "name": "mkt_content",
    "displayName": "Content Assets",
    "description": "Articles, whitepapers, videos, and other marketing content assets",
    "fields": {
      "title": { "type": "string", "required": true, "description": "Content title" },
      "body": { "type": "string", "description": "Full content body or summary" },
      "content_type": { "type": "string", "required": true, "enum": ["blog_post", "whitepaper", "case_study", "video", "infographic", "ebook", "webinar", "podcast"], "description": "Type of content asset" },
      "status": { "type": "string", "required": true, "enum": ["draft", "review", "scheduled", "published", "archived"], "description": "Publication status" },
      "author": { "type": "string", "required": true, "description": "Content author name" },
      "keywords": { "type": "array", "description": "SEO and topic keywords" },
      "channel": { "type": "string", "enum": ["blog", "email", "social", "paid", "partner", "organic"], "description": "Primary distribution channel" },
      "publish_date": { "type": "date", "description": "Scheduled or actual publish date" },
      "views": { "type": "number", "description": "Total view count" },
      "engagement_rate": { "type": "number", "description": "Engagement rate as percentage" }
    }
  },
  {
    "name": "mkt_campaigns",
    "displayName": "Marketing Campaigns",
    "description": "Marketing campaigns with budget tracking and performance metrics",
    "fields": {
      "name": { "type": "string", "required": true, "description": "Campaign name" },
      "objective": { "type": "string", "required": true, "enum": ["awareness", "lead_generation", "conversion", "retention", "brand_building"], "description": "Primary campaign objective" },
      "status": { "type": "string", "required": true, "enum": ["planning", "active", "paused", "completed", "cancelled"], "description": "Campaign status" },
      "budget": { "type": "number", "required": true, "description": "Total campaign budget in USD" },
      "spent": { "type": "number", "description": "Amount spent to date in USD" },
      "channels": { "type": "array", "required": true, "description": "Distribution channels used" },
      "start_date": { "type": "date", "required": true, "description": "Campaign start date" },
      "end_date": { "type": "date", "description": "Campaign end date" },
      "leads_generated": { "type": "number", "description": "Total leads attributed to this campaign" },
      "roi_percentage": { "type": "number", "description": "Return on investment as percentage" }
    }
  },
  {
    "name": "mkt_social_posts",
    "displayName": "Social Media Posts",
    "description": "Social media posts across platforms linked to campaigns",
    "fields": {
      "platform": { "type": "string", "required": true, "enum": ["linkedin", "twitter", "facebook", "instagram", "tiktok", "youtube", "threads"], "description": "Social media platform" },
      "content_text": { "type": "string", "required": true, "description": "Post text content" },
      "post_type": { "type": "string", "required": true, "enum": ["text", "image", "video", "carousel", "story", "reel", "poll"], "description": "Type of social post" },
      "status": { "type": "string", "required": true, "enum": ["draft", "scheduled", "published", "failed"], "description": "Post status" },
      "scheduled_at": { "type": "date", "description": "Scheduled publish time" },
      "published_at": { "type": "date", "description": "Actual publish time" },
      "impressions": { "type": "number", "description": "Total impressions" },
      "engagements": { "type": "number", "description": "Total engagements (likes, comments, shares)" },
      "clicks": { "type": "number", "description": "Link clicks" },
      "campaign_id": { "type": "string", "description": "Associated campaign identifier" }
    }
  },
  {
    "name": "mkt_leads",
    "displayName": "Marketing Leads",
    "description": "Inbound leads generated through content marketing efforts",
    "fields": {
      "email": { "type": "string", "required": true, "description": "Lead email address" },
      "name": { "type": "string", "required": true, "description": "Lead full name" },
      "company": { "type": "string", "description": "Lead company name" },
      "source": { "type": "string", "required": true, "enum": ["blog", "whitepaper", "webinar", "social", "referral", "paid_ad", "organic_search"], "description": "Lead acquisition source" },
      "status": { "type": "string", "required": true, "enum": ["new", "contacted", "qualified", "nurturing", "converted", "lost"], "description": "Lead lifecycle status" },
      "score": { "type": "number", "description": "Lead quality score (0-100)" },
      "campaign_id": { "type": "string", "description": "Originating campaign identifier" },
      "created_at": { "type": "date", "required": true, "description": "Date lead was captured" },
      "converted_at": { "type": "date", "description": "Date lead converted to customer" },
      "estimated_value": { "type": "number", "description": "Estimated deal value in USD" }
    }
  }
]
