[
  {
    "name": "mfg_production_runs",
    "displayName": "Production Runs",
    "description": "Scheduled and active production runs with quantity targets, status, and output tracking",
    "fields": {
      "run_number": {"type": "string", "required": true, "description": "Unique production run identifier"},
      "product_name": {"type": "string", "required": true, "description": "Product being manufactured"},
      "bom_id": {"type": "string", "required": true, "description": "Reference to mfg_bill_of_materials"},
      "status": {"type": "string", "required": true, "enum": ["scheduled", "setup", "running", "paused", "completed", "aborted"], "description": "Current production run status"},
      "planned_quantity": {"type": "number", "required": true, "description": "Target quantity to produce"},
      "actual_quantity": {"type": "number", "description": "Quantity actually produced"},
      "scrap_quantity": {"type": "number", "description": "Units scrapped during this run"},
      "start_time": {"type": "date", "required": true, "description": "Scheduled or actual start time"},
      "end_time": {"type": "date", "description": "Actual completion time"},
      "equipment_id": {"type": "string", "required": true, "description": "Reference to mfg_equipment — primary machine used"},
      "operator": {"type": "string", "required": true, "description": "Lead operator name"},
      "shift": {"type": "string", "required": true, "enum": ["day", "swing", "night"], "description": "Production shift"}
    }
  },
  {
    "name": "mfg_quality_checks",
    "displayName": "Quality Checks",
    "description": "In-process and final quality inspection records with measurements and defect tracking",
    "fields": {
      "check_number": {"type": "string", "required": true, "description": "Unique quality check identifier"},
      "production_run_id": {"type": "string", "required": true, "description": "Reference to mfg_production_runs"},
      "check_type": {"type": "string", "required": true, "enum": ["incoming_material", "in_process", "final", "audit"], "description": "Type of quality inspection"},
      "result": {"type": "string", "required": true, "enum": ["pass", "fail", "conditional_pass"], "description": "Inspection result"},
      "inspector": {"type": "string", "required": true, "description": "Quality inspector name"},
      "check_date": {"type": "date", "required": true, "description": "Date and time of inspection"},
      "sample_size": {"type": "number", "required": true, "description": "Number of units inspected in sample"},
      "defects_found": {"type": "number", "required": true, "description": "Number of defective units in sample"},
      "defect_types": {"type": "array", "description": "Categories of defects found (e.g., dimensional, cosmetic, functional)"},
      "measurements": {"type": "object", "description": "Key measurements recorded during inspection"},
      "corrective_action": {"type": "string", "description": "Corrective action taken for failed checks"},
      "notes": {"type": "string", "description": "Additional inspection notes"}
    }
  },
  {
    "name": "mfg_bill_of_materials",
    "displayName": "Bill of Materials",
    "description": "Product BOMs with component lists, quantities per unit, and assembly instructions",
    "fields": {
      "product_name": {"type": "string", "required": true, "description": "Finished product name"},
      "product_code": {"type": "string", "required": true, "description": "Finished product SKU or part number"},
      "version": {"type": "string", "required": true, "description": "BOM version (e.g., 1.0, 2.1)"},
      "status": {"type": "string", "required": true, "enum": ["draft", "active", "superseded", "retired"], "description": "BOM lifecycle status"},
      "components": {"type": "array", "required": true, "description": "Array of {material_id, quantity_per_unit, unit} objects"},
      "assembly_time_minutes": {"type": "number", "required": true, "description": "Standard assembly time per unit in minutes"},
      "setup_time_minutes": {"type": "number", "required": true, "description": "Machine setup time before production in minutes"},
      "yield_rate": {"type": "number", "description": "Expected yield rate as percentage (e.g., 98.5)"},
      "effective_date": {"type": "date", "required": true, "description": "Date this BOM version became active"},
      "notes": {"type": "string", "description": "Assembly instructions or special handling notes"}
    }
  },
  {
    "name": "mfg_equipment",
    "displayName": "Equipment",
    "description": "Production equipment inventory with maintenance schedules, uptime, and specifications",
    "fields": {
      "name": {"type": "string", "required": true, "description": "Equipment name or identifier"},
      "equipment_type": {"type": "string", "required": true, "enum": ["injection_molder", "extruder", "cnc_mill", "lathe", "press", "oven", "mixer", "conveyor", "packaging", "testing", "other"], "description": "Type of equipment"},
      "manufacturer": {"type": "string", "required": true, "description": "Equipment manufacturer"},
      "model": {"type": "string", "required": true, "description": "Model number"},
      "serial_number": {"type": "string", "required": true, "description": "Serial number"},
      "status": {"type": "string", "required": true, "enum": ["operational", "maintenance", "repair", "offline", "retired"], "description": "Current equipment status"},
      "install_date": {"type": "date", "required": true, "description": "Date equipment was installed"},
      "last_maintenance": {"type": "date", "description": "Date of last preventive maintenance"},
      "next_maintenance": {"type": "date", "description": "Scheduled next maintenance date"},
      "uptime_percent": {"type": "number", "description": "Rolling 30-day uptime percentage"},
      "location": {"type": "string", "required": true, "description": "Factory floor location (e.g., Bay 3, Line 2)"}
    }
  },
  {
    "name": "mfg_raw_materials",
    "displayName": "Raw Materials",
    "description": "Raw material inventory with supplier information, lot traceability, and reorder management",
    "fields": {
      "name": {"type": "string", "required": true, "description": "Material name"},
      "material_code": {"type": "string", "required": true, "description": "Internal material code or part number"},
      "category": {"type": "string", "required": true, "enum": ["resin", "pigment", "additive", "packaging", "fastener", "adhesive", "film", "sheet_stock", "other"], "description": "Material category"},
      "unit": {"type": "string", "required": true, "description": "Unit of measure (e.g., lbs, kg, each, gallons)"},
      "quantity_on_hand": {"type": "number", "required": true, "description": "Current inventory quantity"},
      "reorder_point": {"type": "number", "required": true, "description": "Minimum quantity triggering reorder"},
      "unit_cost": {"type": "number", "required": true, "description": "Cost per unit in USD"},
      "supplier_name": {"type": "string", "required": true, "description": "Primary supplier name"},
      "lot_number": {"type": "string", "description": "Current lot number for traceability"},
      "expiration_date": {"type": "date", "description": "Material expiration date (if applicable)"},
      "last_received": {"type": "date", "description": "Date of most recent delivery"}
    }
  }
]
