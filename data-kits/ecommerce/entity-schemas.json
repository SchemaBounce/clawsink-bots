[
  {
    "name": "ec_products",
    "displayName": "Products",
    "description": "Product catalog with pricing, inventory levels, categories, and search tags",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Product display name"
      },
      "sku": {
        "type": "string",
        "required": true,
        "description": "Stock keeping unit identifier"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Product description for the storefront"
      },
      "category": {
        "type": "string",
        "required": true,
        "description": "Primary product category",
        "enum": ["tops", "bottoms", "dresses", "outerwear", "shoes", "accessories", "activewear"]
      },
      "price": {
        "type": "number",
        "required": true,
        "description": "Current retail price in USD"
      },
      "cost": {
        "type": "number",
        "required": true,
        "description": "Cost of goods sold per unit"
      },
      "inventory_count": {
        "type": "number",
        "required": true,
        "description": "Current inventory quantity across all warehouses"
      },
      "tags": {
        "type": "array",
        "required": false,
        "description": "Searchable tags for filtering and discovery"
      },
      "sizes_available": {
        "type": "array",
        "required": false,
        "description": "Available sizes (XS, S, M, L, XL, etc.)"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Product listing status",
        "enum": ["active", "draft", "archived", "out-of-stock"]
      },
      "image_url": {
        "type": "string",
        "required": false,
        "description": "Primary product image URL"
      }
    }
  },
  {
    "name": "ec_orders",
    "displayName": "Orders",
    "description": "Customer purchase orders with line items, shipping, and fulfillment tracking",
    "fields": {
      "order_number": {
        "type": "string",
        "required": true,
        "description": "Unique order number"
      },
      "customer_name": {
        "type": "string",
        "required": true,
        "description": "Reference to the customer who placed the order"
      },
      "order_date": {
        "type": "date",
        "required": true,
        "description": "Date the order was placed (ISO 8601)"
      },
      "items": {
        "type": "array",
        "required": true,
        "description": "Array of line items with product name, quantity, and unit price"
      },
      "subtotal": {
        "type": "number",
        "required": true,
        "description": "Order subtotal before tax and shipping"
      },
      "tax": {
        "type": "number",
        "required": true,
        "description": "Tax amount"
      },
      "shipping_cost": {
        "type": "number",
        "required": true,
        "description": "Shipping charge"
      },
      "total": {
        "type": "number",
        "required": true,
        "description": "Total order amount (subtotal + tax + shipping)"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Order fulfillment status",
        "enum": ["pending", "processing", "shipped", "delivered", "cancelled", "returned"]
      },
      "shipping_method": {
        "type": "string",
        "required": false,
        "description": "Selected shipping method",
        "enum": ["standard", "express", "overnight", "free-shipping"]
      },
      "tracking_number": {
        "type": "string",
        "required": false,
        "description": "Carrier tracking number"
      }
    }
  },
  {
    "name": "ec_customers",
    "displayName": "Customers",
    "description": "Customer profiles with acquisition channel, order history metrics, and lifetime value",
    "fields": {
      "first_name": {
        "type": "string",
        "required": true,
        "description": "Customer first name"
      },
      "last_name": {
        "type": "string",
        "required": true,
        "description": "Customer last name"
      },
      "email": {
        "type": "string",
        "required": true,
        "description": "Primary email address"
      },
      "phone": {
        "type": "string",
        "required": false,
        "description": "Contact phone number"
      },
      "acquisition_channel": {
        "type": "string",
        "required": false,
        "description": "How the customer was acquired",
        "enum": ["organic-search", "paid-search", "social-media", "email-marketing", "referral", "direct", "affiliate"]
      },
      "total_orders": {
        "type": "number",
        "required": false,
        "description": "Lifetime number of orders placed"
      },
      "total_spent": {
        "type": "number",
        "required": false,
        "description": "Lifetime spend in USD"
      },
      "first_order_date": {
        "type": "date",
        "required": false,
        "description": "Date of first purchase (ISO 8601)"
      },
      "last_order_date": {
        "type": "date",
        "required": false,
        "description": "Date of most recent purchase (ISO 8601)"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Customer account status",
        "enum": ["active", "inactive", "vip", "churned"]
      }
    }
  },
  {
    "name": "ec_returns",
    "displayName": "Returns",
    "description": "Product return and refund records with reason codes and resolution tracking",
    "fields": {
      "return_number": {
        "type": "string",
        "required": true,
        "description": "Unique return/RMA number"
      },
      "order_number": {
        "type": "string",
        "required": true,
        "description": "Reference to the original order"
      },
      "customer_name": {
        "type": "string",
        "required": true,
        "description": "Reference to the customer"
      },
      "items_returned": {
        "type": "array",
        "required": true,
        "description": "Array of returned items with product name and quantity"
      },
      "reason": {
        "type": "string",
        "required": true,
        "description": "Primary reason for return",
        "enum": ["wrong-size", "defective", "not-as-described", "changed-mind", "arrived-late", "wrong-item", "other"]
      },
      "reason_detail": {
        "type": "string",
        "required": false,
        "description": "Customer's free-text explanation of the return reason"
      },
      "return_date": {
        "type": "date",
        "required": true,
        "description": "Date the return was initiated (ISO 8601)"
      },
      "refund_amount": {
        "type": "number",
        "required": true,
        "description": "Amount refunded in USD"
      },
      "resolution": {
        "type": "string",
        "required": true,
        "description": "How the return was resolved",
        "enum": ["refund", "exchange", "store-credit", "denied", "pending"]
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Return processing status",
        "enum": ["initiated", "in-transit", "received", "inspected", "resolved", "cancelled"]
      }
    }
  },
  {
    "name": "ec_price_history",
    "displayName": "Price History",
    "description": "Historical price changes for products to track margin trends and promotional effectiveness",
    "fields": {
      "product_name": {
        "type": "string",
        "required": true,
        "description": "Reference to the product"
      },
      "sku": {
        "type": "string",
        "required": true,
        "description": "Product SKU for cross-reference"
      },
      "old_price": {
        "type": "number",
        "required": true,
        "description": "Previous price in USD"
      },
      "new_price": {
        "type": "number",
        "required": true,
        "description": "New price in USD"
      },
      "change_date": {
        "type": "date",
        "required": true,
        "description": "Date the price change took effect (ISO 8601)"
      },
      "change_reason": {
        "type": "string",
        "required": true,
        "description": "Reason for the price change",
        "enum": ["promotion", "clearance", "cost-increase", "competitive-adjustment", "seasonal", "new-launch", "price-correction"]
      },
      "change_percentage": {
        "type": "number",
        "required": false,
        "description": "Percentage change from old to new price (negative = discount)"
      }
    }
  }
]
