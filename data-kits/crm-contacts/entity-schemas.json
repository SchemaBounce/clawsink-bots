[
  {
    "name": "crm_contacts",
    "displayName": "Contacts",
    "description": "People your organization interacts with — leads, prospects, customers, and partners",
    "fields": {
      "first_name": {
        "type": "string",
        "required": true,
        "description": "Contact first name"
      },
      "last_name": {
        "type": "string",
        "required": true,
        "description": "Contact last name"
      },
      "email": {
        "type": "string",
        "required": true,
        "description": "Primary email address"
      },
      "phone": {
        "type": "string",
        "description": "Phone number"
      },
      "company_id": {
        "type": "string",
        "description": "Reference to crm_companies"
      },
      "title": {
        "type": "string",
        "description": "Job title"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["lead", "prospect", "customer", "churned", "partner"],
        "description": "Contact lifecycle status"
      },
      "source": {
        "type": "string",
        "enum": ["website", "referral", "cold_outreach", "event", "inbound", "partner"],
        "description": "How this contact was acquired"
      },
      "last_contacted_at": {
        "type": "date",
        "description": "Date of most recent interaction"
      },
      "tags": {
        "type": "array",
        "description": "Contact tags for segmentation and filtering"
      }
    }
  },
  {
    "name": "crm_companies",
    "displayName": "Companies",
    "description": "Organizations and accounts in your business network",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Company name"
      },
      "domain": {
        "type": "string",
        "description": "Company website domain"
      },
      "industry": {
        "type": "string",
        "description": "Industry sector"
      },
      "size": {
        "type": "string",
        "enum": ["1-10", "11-50", "51-200", "201-1000", "1001+"],
        "description": "Employee count range"
      },
      "annual_revenue": {
        "type": "number",
        "description": "Estimated annual revenue in USD"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["prospect", "customer", "partner", "churned", "inactive"],
        "description": "Account relationship status"
      },
      "address": {
        "type": "string",
        "description": "Primary business address"
      },
      "city": {
        "type": "string",
        "description": "City"
      },
      "country": {
        "type": "string",
        "description": "Country code (ISO 3166-1 alpha-2)"
      },
      "owner": {
        "type": "string",
        "description": "Account owner or sales rep responsible"
      }
    }
  },
  {
    "name": "crm_deals",
    "displayName": "Deals",
    "description": "Sales opportunities and pipeline tracking",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Deal name or title"
      },
      "value": {
        "type": "number",
        "required": true,
        "description": "Deal value in USD"
      },
      "stage": {
        "type": "string",
        "required": true,
        "enum": ["discovery", "qualification", "proposal", "negotiation", "closed_won", "closed_lost"],
        "description": "Current pipeline stage"
      },
      "probability": {
        "type": "number",
        "description": "Win probability percentage (0-100)"
      },
      "expected_close_date": {
        "type": "date",
        "required": true,
        "description": "Expected close date"
      },
      "contact_id": {
        "type": "string",
        "required": true,
        "description": "Primary contact reference to crm_contacts"
      },
      "company_id": {
        "type": "string",
        "description": "Associated company reference to crm_companies"
      },
      "owner": {
        "type": "string",
        "required": true,
        "description": "Sales rep who owns the deal"
      },
      "source": {
        "type": "string",
        "description": "Deal source or campaign that generated the opportunity"
      },
      "lost_reason": {
        "type": "string",
        "enum": ["price", "competitor", "timing", "no_budget", "no_decision", "other"],
        "description": "Reason for lost deal (only for closed_lost)"
      }
    }
  },
  {
    "name": "crm_interactions",
    "displayName": "Interactions",
    "description": "Sales activities, meeting notes, call logs, and email summaries",
    "fields": {
      "type": {
        "type": "string",
        "required": true,
        "enum": ["call", "email", "meeting", "note", "demo", "follow_up"],
        "description": "Interaction type"
      },
      "subject": {
        "type": "string",
        "required": true,
        "description": "Interaction subject line"
      },
      "notes": {
        "type": "string",
        "description": "Detailed notes from the interaction"
      },
      "summary": {
        "type": "string",
        "description": "Brief summary of outcomes and next steps"
      },
      "contact_id": {
        "type": "string",
        "required": true,
        "description": "Related contact reference to crm_contacts"
      },
      "deal_id": {
        "type": "string",
        "description": "Related deal reference to crm_deals"
      },
      "duration_minutes": {
        "type": "number",
        "description": "Duration of the interaction in minutes"
      },
      "occurred_at": {
        "type": "date",
        "required": true,
        "description": "When the interaction took place"
      },
      "outcome": {
        "type": "string",
        "enum": ["positive", "neutral", "negative", "no_answer"],
        "description": "Overall outcome of the interaction"
      },
      "next_action": {
        "type": "string",
        "description": "Agreed next step after this interaction"
      }
    }
  }
]
