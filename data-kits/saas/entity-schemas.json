      "assignee": {
        "type": "string",
        "description": "Support agent assigned to this ticket"
      },
      "created_at": {
        "type": "date",
        "required": true,
        "description": "When the ticket was created (ISO 8601)"
      },
      "first_response_at": {
        "type": "date",
        "description": "When the first response was sent"
      },
      "resolved_at": {
        "type": "date",
        "description": "When the ticket was resolved"
      },
      "satisfaction_score": {
        "type": "number",
        "description": "Customer satisfaction score (1-5)"
      },
      "escalated": {
        "type": "boolean",
        "description": "Whether this ticket was escalated"
      },
      "tags": {
        "type": "array",
        "description": "Tags for categorization and filtering"
      }
    }
  },
  {
