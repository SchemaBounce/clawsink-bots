[
  {
    "name": "saas_accounts",
    "displayName": "SaaS Accounts",
    "description": "Customer organizations using the SaaS platform",
    "fields": {
      "company_name": {
        "type": "string",
        "required": true,
        "description": "Name of the customer organization"
      },
      "domain": {
        "type": "string",
        "required": true,
        "description": "Primary website domain of the account"
      },
      "plan_tier": {
        "type": "string",
        "required": true,
        "enum": ["free", "starter", "professional", "enterprise"],
        "description": "Current subscription plan tier"
      },
      "mrr": {
        "type": "number",
        "required": true,
        "description": "Monthly recurring revenue in USD"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["trial", "active", "past_due", "churned", "paused"],
        "description": "Account lifecycle status"
      },
      "employee_count": {
        "type": "number",
        "description": "Number of employees at the organization"
      },
      "industry": {
        "type": "string",
        "description": "Industry vertical of the account"
      },
      "signup_date": {
        "type": "date",
        "required": true,
        "description": "Date the account was created (ISO 8601)"
      },
      "owner_email": {
        "type": "string",
        "required": true,
        "description": "Email of the primary account owner"
      },
      "tags": {
        "type": "array",
        "description": "Custom tags for segmentation"
      }
    }
  },
  {
    "name": "saas_subscriptions",
    "displayName": "Subscriptions",
    "description": "Active and historical subscription records for each account",
    "fields": {
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "plan_name": {
        "type": "string",
        "required": true,
        "description": "Name of the subscribed plan"
      },
      "billing_cycle": {
        "type": "string",
        "required": true,
        "enum": ["monthly", "quarterly", "annual"],
        "description": "Billing frequency"
      },
      "amount": {
        "type": "number",
        "required": true,
        "description": "Subscription amount per billing cycle in USD"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["active", "cancelled", "past_due", "trialing", "paused"],
        "description": "Current subscription status"
      },
      "start_date": {
        "type": "date",
        "required": true,
        "description": "Subscription start date"
      },
      "renewal_date": {
        "type": "date",
        "description": "Next renewal date"
      },
      "cancelled_at": {
        "type": "date",
        "description": "Cancellation date if applicable"
      },
      "seats": {
        "type": "number",
        "required": true,
        "description": "Number of licensed seats"
      },
      "discount_percent": {
        "type": "number",
        "description": "Applied discount as a percentage"
      }
    }
  },
  {
    "name": "saas_feature_usage",
    "displayName": "Feature Usage",
    "description": "Per-account feature adoption and usage tracking",
    "fields": {
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "feature_name": {
        "type": "string",
        "required": true,
        "description": "Name of the product feature"
      },
      "feature_category": {
        "type": "string",
        "required": true,
        "enum": ["core", "advanced", "integration", "reporting", "admin"],
        "description": "Feature category"
      },
      "usage_count": {
        "type": "number",
        "required": true,
        "description": "Number of times the feature was used this period"
      },
      "unique_users": {
        "type": "number",
        "description": "Number of unique users who used this feature"
      },
      "first_used_at": {
        "type": "date",
        "required": true,
        "description": "Date the account first used this feature"
      },
      "last_used_at": {
        "type": "date",
        "required": true,
        "description": "Most recent usage timestamp"
      },
      "is_activated": {
        "type": "boolean",
        "required": true,
        "description": "Whether the feature meets the activation threshold"
      }
    }
  },
  {
    "name": "saas_onboarding_progress",
    "displayName": "Onboarding Progress",
    "description": "Step-by-step onboarding completion tracking per account",
    "fields": {
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "step_name": {
        "type": "string",
        "required": true,
        "description": "Name of the onboarding step"
      },
      "step_order": {
        "type": "number",
        "required": true,
        "description": "Sequential order of the step"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["not_started", "in_progress", "completed", "skipped"],
        "description": "Completion status of this step"
      },
      "started_at": {
        "type": "date",
        "description": "When the user began this step"
      },
      "completed_at": {
        "type": "date",
        "description": "When the user finished this step"
      },
      "duration_minutes": {
        "type": "number",
        "description": "Time spent on this step in minutes"
      },
      "assigned_to": {
        "type": "string",
        "description": "Email of the person responsible for completing this step"
      }
    }
  },
  {
    "name": "saas_nps_scores",
    "displayName": "NPS Scores",
    "description": "Net Promoter Score submissions with qualitative feedback",
    "fields": {
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "respondent_email": {
        "type": "string",
        "required": true,
        "description": "Email of the person who submitted the score"
      },
      "score": {
        "type": "number",
        "required": true,
        "description": "NPS score from 0 to 10"
      },
      "category": {
        "type": "string",
        "required": true,
        "enum": ["detractor", "passive", "promoter"],
        "description": "NPS category based on score (0-6 detractor, 7-8 passive, 9-10 promoter)"
      },
      "feedback_text": {
        "type": "string",
        "description": "Free-text feedback from the respondent"
      },
      "submitted_at": {
        "type": "date",
        "required": true,
        "description": "Date the NPS survey was submitted"
      },
      "survey_trigger": {
        "type": "string",
        "enum": ["quarterly", "post_onboarding", "post_support", "annual"],
        "description": "What triggered this NPS survey"
      },
      "follow_up_status": {
        "type": "string",
        "enum": ["pending", "contacted", "resolved", "no_action"],
        "description": "Status of follow-up action for detractors"
      }
    }
  },
  {
    "name": "saas_incidents",
    "displayName": "Incidents",
    "description": "Production incident tracking with severity, impact, and resolution details",
    "fields": {
      "title": {
        "type": "string",
        "required": true,
        "description": "Short title summarizing the incident"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Detailed description of what happened"
      },
      "severity": {
        "type": "string",
        "required": true,
        "enum": ["sev1", "sev2", "sev3", "sev4"],
        "description": "Incident severity level (sev1 = critical, sev4 = minor)"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["detected", "investigating", "mitigating", "resolved", "postmortem"],
        "description": "Current incident lifecycle status"
      },
      "resolution": {
        "type": "string",
        "description": "Description of how the incident was resolved"
      },
      "root_cause": {
        "type": "string",
        "description": "Identified root cause of the incident"
      },
      "incident_commander": {
        "type": "string",
        "required": true,
        "description": "Person leading the incident response"
      },
      "affected_services": {
        "type": "array",
        "description": "List of services impacted by the incident"
      },
      "detected_at": {
        "type": "date",
        "required": true,
        "description": "When the incident was first detected (ISO 8601)"
      },
      "resolved_at": {
        "type": "date",
        "description": "When the incident was fully resolved"
      },
      "customer_impact": {
        "type": "string",
        "enum": ["none", "degraded", "partial_outage", "full_outage"],
        "description": "Level of customer-facing impact"
      },
      "affected_account_count": {
        "type": "number",
        "description": "Number of customer accounts affected"
      },
      "is_recurring": {
        "type": "boolean",
        "description": "Whether this incident is a repeat of a previous one"
      },
      "related_deployment_version": {
        "type": "string",
        "description": "Version of the deployment that may have caused this incident"
      }
    }
  },
  {
    "name": "saas_deployments",
    "displayName": "Deployments",
    "description": "Deployment records with versioning, rollback tracking, and deploy type",
    "fields": {
      "version": {
        "type": "string",
        "required": true,
        "description": "Version being deployed (e.g., v2.4.1)"
      },
      "service_name": {
        "type": "string",
        "required": true,
        "description": "Name of the service being deployed"
      },
      "environment": {
        "type": "string",
        "required": true,
        "enum": ["staging", "canary", "production"],
        "description": "Target deployment environment"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["pending", "in_progress", "succeeded", "failed", "rolled_back"],
        "description": "Current deployment status"
      },
      "deploy_type": {
        "type": "string",
        "required": true,
        "enum": ["rolling", "blue_green", "canary", "recreate", "hotfix"],
        "description": "Deployment strategy used"
      },
      "deployer": {
        "type": "string",
        "required": true,
        "description": "Person or system that initiated the deploy"
      },
      "commit_sha": {
        "type": "string",
        "description": "Git commit SHA being deployed"
      },
      "change_summary": {
        "type": "string",
        "description": "Brief summary of changes in this deployment"
      },
      "started_at": {
        "type": "date",
        "required": true,
        "description": "When the deployment started (ISO 8601)"
      },
      "completed_at": {
        "type": "date",
        "description": "When the deployment finished"
      },
      "rollback_version": {
        "type": "string",
        "description": "Version to roll back to if this deploy fails"
      },
      "is_rollback": {
        "type": "boolean",
        "description": "Whether this deployment is itself a rollback"
      }
    }
  },
  {
    "name": "saas_content",
    "displayName": "Content",
    "description": "Content assets with engagement metrics and publishing workflow",
    "fields": {
      "title": {
        "type": "string",
        "required": true,
        "description": "Title of the content piece"
      },
      "body": {
        "type": "string",
        "description": "Full body text of the content"
      },
      "content_type": {
        "type": "string",
        "required": true,
        "enum": ["blog_post", "docs_page", "tutorial", "changelog", "case_study", "api_reference", "video_script", "webinar"],
        "description": "Type of content asset"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["idea", "draft", "review", "scheduled", "published", "archived"],
        "description": "Current publishing workflow status"
      },
      "author": {
        "type": "string",
        "required": true,
        "description": "Author of the content"
      },
      "target_audience": {
        "type": "string",
        "enum": ["developers", "devops", "product_managers", "executives", "general"],
        "description": "Primary target audience for this content"
      },
      "keywords": {
        "type": "array",
        "description": "SEO and discovery keywords"
      },
      "publish_date": {
        "type": "date",
        "description": "Date the content was or will be published"
      },
      "views": {
        "type": "number",
        "description": "Total page views"
      },
      "unique_visitors": {
        "type": "number",
        "description": "Unique visitors who viewed this content"
      },
      "avg_time_on_page_seconds": {
        "type": "number",
        "description": "Average time readers spend on this page in seconds"
      },
      "engagement_rate": {
        "type": "number",
        "description": "Engagement rate as a decimal (e.g., 0.045 = 4.5%)"
      },
      "conversion_count": {
        "type": "number",
        "description": "Number of conversions attributed to this content"
      }
    }
  },
  {
    "name": "saas_community_metrics",
    "displayName": "Community Metrics",
    "description": "Cross-platform community engagement and growth tracking",
    "fields": {
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["github", "discord", "slack_community", "forum", "stack_overflow", "twitter", "linkedin", "youtube"],
        "description": "Community platform being tracked"
      },
      "metric_date": {
        "type": "date",
        "required": true,
        "description": "Date of the metric snapshot (ISO 8601)"
      },
      "followers_or_members": {
        "type": "number",
        "required": true,
        "description": "Total followers or community members on this platform"
      },
      "new_members_period": {
        "type": "number",
        "description": "New members added during this reporting period"
      },
      "active_contributors": {
        "type": "number",
        "description": "Number of members who actively contributed"
      },
      "posts_or_contributions": {
        "type": "number",
        "description": "Total posts, comments, or contributions in the period"
      },
      "github_stars": {
        "type": "number",
        "description": "GitHub repository star count (GitHub platform only)"
      },
      "github_open_issues": {
        "type": "number",
        "description": "Open issue count (GitHub platform only)"
      },
      "github_open_prs": {
        "type": "number",
        "description": "Open pull request count (GitHub platform only)"
      },
      "engagement_rate": {
        "type": "number",
        "description": "Engagement rate as a decimal (active / total members)"
      },
      "sentiment_trend": {
        "type": "string",
        "enum": ["improving", "stable", "declining"],
        "description": "Overall sentiment direction for this platform"
      }
    }
  },
  {
    "name": "saas_deals",
    "displayName": "Deals",
    "description": "Sales pipeline deals with stage tracking and win/loss analysis",
    "fields": {
      "deal_name": {
        "type": "string",
        "required": true,
        "description": "Name or title of the deal"
      },
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "stage": {
        "type": "string",
        "required": true,
        "enum": ["prospecting", "discovery", "demo", "proposal", "negotiation", "closed_won", "closed_lost"],
        "description": "Current deal stage in the pipeline"
      },
      "deal_type": {
        "type": "string",
        "required": true,
        "enum": ["new_business", "expansion", "renewal", "upsell", "cross_sell"],
        "description": "Type of sales opportunity"
      },
      "annual_value": {
        "type": "number",
        "required": true,
        "description": "Annual contract value of the deal"
      },
      "probability": {
        "type": "number",
        "description": "Win probability as a percentage (0-100)"
      },
      "expected_close_date": {
        "type": "date",
        "required": true,
        "description": "Expected date the deal will close"
      },
      "owner": {
        "type": "string",
        "required": true,
        "description": "Sales rep who owns this deal"
      },
      "source": {
        "type": "string",
        "enum": ["inbound", "outbound", "referral", "partner", "event", "product_led"],
        "description": "How this deal originated"
      },
      "created_at": {
        "type": "date",
        "required": true,
        "description": "When the deal was created (ISO 8601)"
      },
      "closed_at": {
        "type": "date",
        "description": "When the deal was closed (won or lost)"
      },
      "lost_reason": {
        "type": "string",
        "enum": ["price", "timing", "no_budget", "no_decision", "chose_alternative", "feature_gap", "other"],
        "description": "Reason the deal was lost (closed_lost only)"
      },
      "plan_tier": {
        "type": "string",
        "enum": ["starter", "professional", "enterprise"],
        "description": "Plan tier the deal is targeting"
      }
    }
  },
  {
    "name": "saas_revenue_metrics",
    "displayName": "Revenue Metrics",
    "description": "Periodic MRR/ARR snapshots with retention and expansion metrics",
    "fields": {
      "period_start": {
        "type": "date",
        "required": true,
        "description": "Start date of the reporting period"
      },
      "period_end": {
        "type": "date",
        "required": true,
        "description": "End date of the reporting period"
      },
      "period_type": {
        "type": "string",
        "required": true,
        "enum": ["weekly", "monthly", "quarterly"],
        "description": "Type of reporting period"
      },
      "total_mrr": {
        "type": "number",
        "required": true,
        "description": "Total monthly recurring revenue at period end"
      },
      "new_mrr": {
        "type": "number",
        "required": true,
        "description": "MRR from new customers acquired in this period"
      },
      "expansion_mrr": {
        "type": "number",
        "required": true,
        "description": "MRR increase from existing customer upgrades"
      },
      "contraction_mrr": {
        "type": "number",
        "required": true,
        "description": "MRR decrease from existing customer downgrades"
      },
      "churned_mrr": {
        "type": "number",
        "required": true,
        "description": "MRR lost from customer cancellations"
      },
      "net_new_mrr": {
        "type": "number",
        "required": true,
        "description": "Net change in MRR (new + expansion - contraction - churned)"
      },
      "total_arr": {
        "type": "number",
        "description": "Annual recurring revenue (MRR * 12)"
      },
      "net_revenue_retention": {
        "type": "number",
        "description": "Net revenue retention rate as a percentage"
      },
      "gross_revenue_retention": {
        "type": "number",
        "description": "Gross revenue retention rate as a percentage"
      },
      "active_accounts": {
        "type": "number",
        "description": "Total number of active paying accounts"
      },
      "arpu": {
        "type": "number",
        "description": "Average revenue per user/account"
      }
    }
  },
  {
    "name": "saas_support_tickets",
    "displayName": "Support Tickets",
    "description": "Customer support ticket lifecycle with SLA tracking and satisfaction",
    "fields": {
      "subject": {
        "type": "string",
        "required": true,
        "description": "Subject line of the support ticket"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Detailed description of the issue"
      },
      "account_id": {
        "type": "string",
        "required": true,
        "description": "Reference to saas_accounts"
      },
      "submitter_email": {
        "type": "string",
        "required": true,
        "description": "Email of the person who submitted the ticket"
      },
      "priority": {
        "type": "string",
        "required": true,
        "enum": ["low", "medium", "high", "critical"],
        "description": "Ticket priority level"
      },
      "category": {
        "type": "string",
        "required": true,
        "enum": ["bug", "question", "feature_request", "billing", "onboarding", "integration", "performance", "security", "data_issue"],
