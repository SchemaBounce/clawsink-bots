    "saas_incidents": [
      {
        "title": "Ingest API latency spike — P99 above 5s",
        "description": "The ingest API experienced elevated latency with P99 response times exceeding 5 seconds. Customers reported delayed event processing. Root cause traced to a Redis connection pool exhaustion after a burst of new environment provisioning.",
        "severity": "sev2",
        "status": "postmortem",
        "resolution": "Increased Redis connection pool size from 50 to 200 and added connection pool monitoring alerts.",
        "root_cause": "Redis connection pool exhaustion caused by concurrent environment provisioning spike during onboarding week.",
        "incident_commander": "alex.rivera@schemabounce.com",
        "affected_services": ["ingest-api", "pipeline-worker"],
        "detected_at": "2026-03-05T14:22:00Z",
        "resolved_at": "2026-03-05T15:08:00Z",
        "customer_impact": "degraded",
        "affected_account_count": 34,
        "is_recurring": false,
        "related_deployment_version": "v2.4.1"
      },
      {
        "title": "Dashboard rendering failure for enterprise accounts",
        "description": "Enterprise accounts with more than 50 dashboard widgets experienced blank page rendering. The frontend bundle exceeded the memory limit when processing large widget configurations.",
        "severity": "sev3",
        "status": "resolved",
        "resolution": "Implemented lazy loading for dashboard widgets and increased frontend memory allocation.",
        "root_cause": "Frontend memory limit hit when rendering dashboards with 50+ widgets due to eager initialization of all chart libraries.",
        "incident_commander": "nina.patel@schemabounce.com",
        "affected_services": ["frontend", "dashboard-service"],
        "detected_at": "2026-02-18T09:15:00Z",
        "resolved_at": "2026-02-18T11:42:00Z",
        "customer_impact": "partial_outage",
        "affected_account_count": 8,
        "is_recurring": false,
        "related_deployment_version": "v2.3.8"
      },
      {
        "title": "CDC pipeline data loss — MySQL connector",
        "description": "The MySQL CDC connector dropped events during a binlog rotation on high-throughput accounts. Approximately 1,200 events were lost across 3 accounts over a 12-minute window.",
        "severity": "sev1",
        "status": "postmortem",
        "resolution": "Patched binlog position tracking to persist checkpoint before rotation. Added event count reconciliation job.",
        "root_cause": "Binlog position checkpoint was written after rotation completed, creating a gap window where events could be missed.",
        "incident_commander": "alex.rivera@schemabounce.com",
        "affected_services": ["pipeline-worker", "mysql-connector"],
        "detected_at": "2026-01-29T03:41:00Z",
        "resolved_at": "2026-01-29T04:53:00Z",
        "customer_impact": "partial_outage",
        "affected_account_count": 3,
        "is_recurring": true,
        "related_deployment_version": "v2.3.5"
      },
      {
        "title": "Webhook delivery backlog — Slack sink",
        "description": "Slack sink webhook deliveries backed up to over 45,000 queued messages due to Slack API rate limiting. Delivery latency exceeded 30 minutes for affected accounts.",
        "severity": "sev3",
        "status": "resolved",
        "resolution": "Implemented per-workspace rate limiting with exponential backoff and added queue depth alerting at 10,000 messages.",
        "root_cause": "A single enterprise account triggered 20,000 events in a burst, consuming the shared Slack API rate limit for all accounts.",
        "incident_commander": "nina.patel@schemabounce.com",
        "affected_services": ["sink-worker", "slack-sink"],
        "detected_at": "2026-02-10T16:30:00Z",
        "resolved_at": "2026-02-10T18:15:00Z",
        "customer_impact": "degraded",
        "affected_account_count": 12,
        "is_recurring": false,
        "related_deployment_version": "v2.4.0"
      }
    ],
