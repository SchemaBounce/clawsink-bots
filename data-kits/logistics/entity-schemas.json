[
  {
    "name": "log_shipments",
    "displayName": "Shipments",
    "description": "Outbound shipments with carrier assignment, tracking, and delivery status",
    "fields": {
      "tracking_number": {"type": "string", "required": true, "description": "Carrier tracking number"},
      "carrier_id": {"type": "string", "required": true, "description": "Reference to log_carriers"},
      "fulfillment_order_id": {"type": "string", "required": true, "description": "Reference to log_fulfillment_orders"},
      "status": {"type": "string", "required": true, "enum": ["label_created", "picked_up", "in_transit", "out_for_delivery", "delivered", "exception", "returned"], "description": "Current shipment status"},
      "service_level": {"type": "string", "required": true, "enum": ["ground", "express", "overnight", "freight", "economy"], "description": "Shipping service level"},
      "ship_date": {"type": "date", "required": true, "description": "Date shipment was dispatched"},
      "estimated_delivery": {"type": "date", "required": true, "description": "Estimated delivery date"},
      "actual_delivery": {"type": "date", "description": "Actual delivery date"},
      "weight_lbs": {"type": "number", "required": true, "description": "Package weight in pounds"},
      "shipping_cost": {"type": "number", "required": true, "description": "Total shipping cost in USD"},
      "destination_zip": {"type": "string", "required": true, "description": "Destination ZIP/postal code"}
    }
  },
  {
    "name": "log_warehouse_stock",
    "displayName": "Warehouse Stock",
    "description": "Real-time inventory positions by SKU, warehouse location, and lot",
    "fields": {
      "sku": {"type": "string", "required": true, "description": "Stock keeping unit identifier"},
      "product_name": {"type": "string", "required": true, "description": "Product display name"},
      "quantity_on_hand": {"type": "number", "required": true, "description": "Current quantity in stock"},
      "quantity_reserved": {"type": "number", "required": true, "description": "Quantity reserved for pending orders"},
      "quantity_available": {"type": "number", "required": true, "description": "Available to promise (on_hand - reserved)"},
      "location": {"type": "string", "required": true, "description": "Warehouse bin/shelf location (e.g., A-12-3)"},
      "lot_number": {"type": "string", "description": "Lot or batch number for traceability"},
      "reorder_point": {"type": "number", "required": true, "description": "Quantity threshold triggering reorder"},
      "unit_cost": {"type": "number", "description": "Cost per unit in USD"},
      "last_counted": {"type": "date", "description": "Date of last physical inventory count"}
    }
  },
  {
    "name": "log_carriers",
    "displayName": "Carriers",
    "description": "Shipping carrier profiles with service levels, rates, and performance tracking",
    "fields": {
      "name": {"type": "string", "required": true, "description": "Carrier company name"},
      "carrier_code": {"type": "string", "required": true, "description": "Short code for the carrier (e.g., UPS, FEDEX, USPS)"},
      "account_number": {"type": "string", "required": true, "description": "Business account number with carrier"},
      "service_levels": {"type": "array", "required": true, "description": "Available service levels (ground, express, etc.)"},
      "avg_transit_days": {"type": "number", "description": "Average transit time in business days"},
      "on_time_rate": {"type": "number", "description": "Percentage of shipments delivered on time"},
      "damage_rate": {"type": "number", "description": "Percentage of shipments with damage claims"},
      "contact_email": {"type": "string", "description": "Account rep contact email"},
      "contract_end_date": {"type": "date", "description": "Current rate contract expiration"},
      "active": {"type": "boolean", "required": true, "description": "Whether this carrier is currently used"}
    }
  },
  {
    "name": "log_fulfillment_orders",
    "displayName": "Fulfillment Orders",
    "description": "Customer orders queued for warehouse picking, packing, and shipping",
    "fields": {
      "order_number": {"type": "string", "required": true, "description": "External order reference number"},
      "status": {"type": "string", "required": true, "enum": ["pending", "picking", "packing", "shipped", "cancelled", "backordered"], "description": "Order fulfillment status"},
      "priority": {"type": "string", "required": true, "enum": ["standard", "expedited", "rush"], "description": "Fulfillment priority level"},
      "order_date": {"type": "date", "required": true, "description": "Date order was placed"},
      "ship_by_date": {"type": "date", "required": true, "description": "Required ship-by date based on SLA"},
      "line_items": {"type": "array", "required": true, "description": "Array of {sku, quantity, product_name} objects"},
      "total_items": {"type": "number", "required": true, "description": "Total number of items in the order"},
      "customer_name": {"type": "string", "required": true, "description": "Customer or recipient name"},
      "shipping_address": {"type": "string", "required": true, "description": "Full shipping address"},
      "notes": {"type": "string", "description": "Special handling or delivery instructions"}
    }
  },
  {
    "name": "log_receiving",
    "displayName": "Receiving",
    "description": "Inbound receiving records for purchase orders, transfers, and returns",
    "fields": {
      "po_number": {"type": "string", "required": true, "description": "Purchase order or transfer reference number"},
      "supplier_name": {"type": "string", "required": true, "description": "Supplier or source name"},
      "status": {"type": "string", "required": true, "enum": ["expected", "arrived", "inspecting", "put_away", "completed", "rejected"], "description": "Receiving status"},
      "expected_date": {"type": "date", "required": true, "description": "Expected arrival date"},
      "received_date": {"type": "date", "description": "Actual arrival date"},
      "line_items": {"type": "array", "required": true, "description": "Array of {sku, expected_qty, received_qty} objects"},
      "total_units_expected": {"type": "number", "required": true, "description": "Total units expected in shipment"},
      "total_units_received": {"type": "number", "description": "Total units actually received"},
      "discrepancy_notes": {"type": "string", "description": "Notes on quantity or quality discrepancies"},
      "receiving_dock": {"type": "string", "description": "Dock or bay used for receiving"}
    }
  }
]
