[
  {
    "name": "ops_inventory",
    "displayName": "Inventory",
    "description": "Stock levels by SKU with reorder points, warehouse location, and supplier linkage",
    "fields": {
      "sku": {
        "type": "string",
        "required": true,
        "description": "Stock keeping unit identifier"
      },
      "product_name": {
        "type": "string",
        "required": true,
        "description": "Product display name"
      },
      "quantity_on_hand": {
        "type": "number",
        "required": true,
        "description": "Current quantity in stock"
      },
      "quantity_reserved": {
        "type": "number",
        "required": true,
        "description": "Quantity reserved for pending orders"
      },
      "quantity_available": {
        "type": "number",
        "required": true,
        "description": "Available to promise (on_hand - reserved)"
      },
      "reorder_point": {
        "type": "number",
        "required": true,
        "description": "Quantity threshold triggering a reorder"
      },
      "reorder_quantity": {
        "type": "number",
        "required": true,
        "description": "Standard quantity to order when reorder point is reached"
      },
      "supplier_id": {
        "type": "string",
        "required": true,
        "description": "Reference to ops_suppliers"
      },
      "warehouse_location": {
        "type": "string",
        "required": true,
        "description": "Bin or shelf location (e.g., A-12-3)"
      },
      "unit_cost": {
        "type": "number",
        "description": "Cost per unit in USD"
      },
      "last_counted": {
        "type": "date",
        "description": "Date of last physical inventory count"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["in_stock", "low_stock", "critical", "out_of_stock", "discontinued"],
        "description": "Current stock status"
      }
    }
  },
  {
    "name": "ops_orders",
    "displayName": "Orders",
    "description": "Customer orders with fulfillment status, SLA tracking, and line items",
    "fields": {
      "order_number": {
        "type": "string",
        "required": true,
        "description": "Unique order reference number"
      },
      "customer_name": {
        "type": "string",
        "required": true,
        "description": "Customer or recipient name"
      },
      "order_date": {
        "type": "date",
        "required": true,
        "description": "Date the order was placed"
      },
      "ship_by_date": {
        "type": "date",
        "required": true,
        "description": "Required ship-by date based on SLA"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["pending", "picking", "packing", "shipped", "delivered", "cancelled", "backordered"],
        "description": "Order fulfillment status"
      },
      "priority": {
        "type": "string",
        "required": true,
        "enum": ["standard", "expedited", "rush"],
        "description": "Fulfillment priority level"
      },
      "line_items": {
        "type": "array",
        "required": true,
        "description": "Array of {sku, product_name, quantity, unit_price} objects"
      },
      "total_value": {
        "type": "number",
        "required": true,
        "description": "Total order value in USD"
      },
      "shipping_address": {
        "type": "string",
        "required": true,
        "description": "Full shipping destination address"
      },
      "notes": {
        "type": "string",
        "description": "Special handling or delivery instructions"
      }
    }
  },
  {
    "name": "ops_shipments",
    "displayName": "Shipments",
    "description": "Outbound shipment records with carrier, tracking, and delivery status",
    "fields": {
      "tracking_number": {
        "type": "string",
        "required": true,
        "description": "Carrier tracking number"
      },
      "order_number": {
        "type": "string",
        "required": true,
        "description": "Reference to ops_orders"
      },
      "carrier": {
        "type": "string",
        "required": true,
        "description": "Carrier name (e.g., UPS, FedEx, USPS)"
      },
      "service_level": {
        "type": "string",
        "required": true,
        "enum": ["ground", "express", "overnight", "freight", "economy"],
        "description": "Shipping service level"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["label_created", "picked_up", "in_transit", "out_for_delivery", "delivered", "exception", "returned"],
        "description": "Current shipment status"
      },
      "ship_date": {
        "type": "date",
        "required": true,
        "description": "Date the shipment was dispatched"
      },
      "estimated_delivery": {
        "type": "date",
        "required": true,
        "description": "Estimated delivery date"
      },
      "actual_delivery": {
        "type": "date",
        "description": "Actual delivery date"
      },
      "shipping_cost": {
        "type": "number",
        "required": true,
        "description": "Total shipping cost in USD"
      },
      "exception_reason": {
        "type": "string",
        "description": "Reason for any delivery exception"
      }
    }
  },
  {
    "name": "ops_suppliers",
    "displayName": "Suppliers",
    "description": "Vendor profiles with lead times, reliability scores, and contract terms",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "Supplier company name"
      },
      "contact_email": {
        "type": "string",
        "required": true,
        "description": "Primary supplier contact email"
      },
      "lead_time_days": {
        "type": "number",
        "required": true,
        "description": "Standard lead time from order to delivery in business days"
      },
      "on_time_rate": {
        "type": "number",
        "description": "Percentage of orders delivered on time (0-100)"
      },
      "quality_score": {
        "type": "number",
        "description": "Supplier quality rating (1.0-5.0)"
      },
      "contract_end_date": {
        "type": "date",
        "description": "Current contract expiration date"
      },
      "payment_terms": {
        "type": "string",
        "description": "Payment terms (e.g., Net-30, Net-60)"
      },
      "categories": {
        "type": "array",
        "required": true,
        "description": "Product categories supplied"
      },
      "active": {
        "type": "boolean",
        "required": true,
        "description": "Whether this supplier is currently active"
      }
    }
  },
  {
    "name": "ops_price_rules",
    "displayName": "Price Rules",
    "description": "Active pricing rules with conditions, target margins, and effective dates",
    "fields": {
      "rule_name": {
        "type": "string",
        "required": true,
        "description": "Human-readable pricing rule name"
      },
      "rule_type": {
        "type": "string",
        "required": true,
        "enum": ["fixed", "percentage", "competitive", "volume", "seasonal", "clearance"],
        "description": "Type of pricing rule"
      },
      "applies_to": {
        "type": "string",
        "required": true,
        "description": "SKU, category, or 'all' this rule applies to"
      },
      "adjustment_value": {
        "type": "number",
        "required": true,
        "description": "Price adjustment amount or percentage (negative = discount)"
      },
      "target_margin_pct": {
        "type": "number",
        "description": "Target gross margin percentage this rule is designed to achieve"
      },
      "effective_from": {
        "type": "date",
        "required": true,
        "description": "Date the rule takes effect"
      },
      "effective_to": {
        "type": "date",
        "description": "Date the rule expires (null = ongoing)"
      },
      "priority": {
        "type": "number",
        "required": true,
        "description": "Rule priority when multiple rules apply (lower = higher priority)"
      },
      "active": {
        "type": "boolean",
        "required": true,
        "description": "Whether this rule is currently active"
      }
    }
  }
]
