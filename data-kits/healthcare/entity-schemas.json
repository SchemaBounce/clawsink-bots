[
  {
    "name": "hc_patients",
    "displayName": "Patients",
    "description": "Patient demographic and insurance information for scheduling and billing",
    "fields": {
      "first_name": {
        "type": "string",
        "required": true,
        "description": "Patient first name"
      },
      "last_name": {
        "type": "string",
        "required": true,
        "description": "Patient last name"
      },
      "date_of_birth": {
        "type": "date",
        "required": true,
        "description": "Patient date of birth (ISO 8601)"
      },
      "gender": {
        "type": "string",
        "required": false,
        "description": "Patient gender identity",
        "enum": ["male", "female", "non-binary", "prefer-not-to-say"]
      },
      "phone": {
        "type": "string",
        "required": true,
        "description": "Primary contact phone number"
      },
      "email": {
        "type": "string",
        "required": false,
        "description": "Contact email address"
      },
      "insurance_provider": {
        "type": "string",
        "required": false,
        "description": "Primary insurance company name"
      },
      "insurance_id": {
        "type": "string",
        "required": false,
        "description": "Insurance member/subscriber ID"
      },
      "primary_provider": {
        "type": "string",
        "required": false,
        "description": "Assigned primary care provider name"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Patient account status",
        "enum": ["active", "inactive", "deceased", "transferred"]
      }
    }
  },
  {
    "name": "hc_appointments",
    "displayName": "Appointments",
    "description": "Patient appointment scheduling with visit type and provider assignment",
    "fields": {
      "patient_name": {
        "type": "string",
        "required": true,
        "description": "Reference to the patient"
      },
      "provider_name": {
        "type": "string",
        "required": true,
        "description": "Name of the provider/physician for this appointment"
      },
      "date": {
        "type": "date",
        "required": true,
        "description": "Appointment date (ISO 8601)"
      },
      "time": {
        "type": "string",
        "required": true,
        "description": "Scheduled start time (HH:MM format)"
      },
      "duration_minutes": {
        "type": "number",
        "required": true,
        "description": "Scheduled duration in minutes"
      },
      "visit_type": {
        "type": "string",
        "required": true,
        "description": "Type of visit",
        "enum": ["new-patient", "follow-up", "annual-wellness", "sick-visit", "procedure", "telehealth", "urgent"]
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Appointment status",
        "enum": ["scheduled", "checked-in", "in-progress", "completed", "no-show", "cancelled", "rescheduled"]
      },
      "check_in_time": {
        "type": "string",
        "required": false,
        "description": "Actual check-in time (HH:MM format)"
      },
      "chief_complaint": {
        "type": "string",
        "required": false,
        "description": "Patient's primary reason for visit"
      },
      "copay_amount": {
        "type": "number",
        "required": false,
        "description": "Copay collected at time of visit"
      }
    }
  },
  {
    "name": "hc_claims",
    "displayName": "Insurance Claims",
    "description": "Insurance claims with CPT codes, amounts, and denial tracking for revenue cycle management",
    "fields": {
      "patient_name": {
        "type": "string",
        "required": true,
        "description": "Reference to the patient this claim is for"
      },
      "provider_name": {
        "type": "string",
        "required": true,
        "description": "Rendering provider name"
      },
      "service_date": {
        "type": "date",
        "required": true,
        "description": "Date of service (ISO 8601)"
      },
      "cpt_codes": {
        "type": "array",
        "required": true,
        "description": "CPT procedure codes billed"
      },
      "icd_codes": {
        "type": "array",
        "required": false,
        "description": "ICD-10 diagnosis codes"
      },
      "billed_amount": {
        "type": "number",
        "required": true,
        "description": "Total amount billed to insurance"
      },
      "allowed_amount": {
        "type": "number",
        "required": false,
        "description": "Insurance-allowed amount after adjustments"
      },
      "paid_amount": {
        "type": "number",
        "required": false,
        "description": "Amount actually paid by insurance"
      },
      "patient_responsibility": {
        "type": "number",
        "required": false,
        "description": "Amount owed by the patient (copay + deductible + coinsurance)"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Claim processing status",
        "enum": ["submitted", "accepted", "denied", "appealed", "paid", "patient-balance"]
      },
      "denial_reason": {
        "type": "string",
        "required": false,
        "description": "Reason code or description for denied claims"
      }
    }
  },
  {
    "name": "hc_compliance_items",
    "displayName": "Compliance Items",
    "description": "Regulatory compliance requirements and checklist items for HIPAA, OSHA, and practice standards",
    "fields": {
      "requirement": {
        "type": "string",
        "required": true,
        "description": "Short title of the compliance requirement"
      },
      "description": {
        "type": "string",
        "required": true,
        "description": "Detailed description of what is required"
      },
      "framework": {
        "type": "string",
        "required": true,
        "description": "Regulatory framework this item falls under",
        "enum": ["hipaa-privacy", "hipaa-security", "osha", "cms", "state-medical-board", "pci-dss", "internal"]
      },
      "frequency": {
        "type": "string",
        "required": true,
        "description": "How often this requirement must be met",
        "enum": ["one-time", "annual", "quarterly", "monthly", "ongoing", "as-needed"]
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current compliance status",
        "enum": ["compliant", "non-compliant", "in-progress", "due-soon", "not-applicable"]
      },
      "due_date": {
        "type": "date",
        "required": false,
        "description": "Next due date for this compliance item (ISO 8601)"
      },
      "last_completed": {
        "type": "date",
        "required": false,
        "description": "Date this item was last completed"
      },
      "responsible_role": {
        "type": "string",
        "required": false,
        "description": "Role or person responsible for this item"
      },
      "evidence_url": {
        "type": "string",
        "required": false,
        "description": "Link to documentation or evidence of compliance"
      }
    }
  },
  {
    "name": "hc_staff_credentials",
    "displayName": "Staff Credentials",
    "description": "Provider licenses, certifications, DEA registrations, and malpractice insurance tracking",
    "fields": {
      "staff_name": {
        "type": "string",
        "required": true,
        "description": "Full name of the credentialed staff member"
      },
      "role": {
        "type": "string",
        "required": true,
        "description": "Clinical role",
        "enum": ["physician", "nurse-practitioner", "physician-assistant", "registered-nurse", "medical-assistant", "office-manager"]
      },
      "credential_type": {
        "type": "string",
        "required": true,
        "description": "Type of credential",
        "enum": ["medical-license", "dea-registration", "board-certification", "npi", "malpractice-insurance", "cpr-certification", "state-license"]
      },
      "credential_number": {
        "type": "string",
        "required": true,
        "description": "License or certification number"
      },
      "issuing_body": {
        "type": "string",
        "required": true,
        "description": "Organization that issued the credential"
      },
      "issue_date": {
        "type": "date",
        "required": true,
        "description": "Date the credential was issued (ISO 8601)"
      },
      "expiration_date": {
        "type": "date",
        "required": true,
        "description": "Credential expiration date (ISO 8601)"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "Current credential status",
        "enum": ["active", "expiring-soon", "expired", "suspended", "pending-renewal"]
      },
      "payer_enrolled": {
        "type": "array",
        "required": false,
        "description": "Insurance payers this provider is credentialed with"
      }
    }
  }
]
